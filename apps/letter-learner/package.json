{
  "name": "letter-learner",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "expo start --dev-client",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios --no-bundler",
    "ios:device": "expo run:ios --device --no-bundler",
    "web": "expo start --web",
    "lint": "eslint .",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "web:export": "expo export --platform web",
    "generate-audio": "node ./scripts/generate-audio.mjs"
  },
  "dependencies": {
    "@education/app-config": "0.0.0",
    "@education/design": "0.0.0",
    "@education/legal-pages": "0.0.0",
    "@education/ui": "0.0.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.11",
    "expo-audio": "~55.0.14",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "^55.0.22",
    "expo-device": "~55.0.12",
    "expo-font": "~55.0.6",
    "expo-haptics": "^55.0.12",
    "expo-linking": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.13",
    "expo-web-browser": "~55.0.12",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@education/eslint-config": "0.0.0",
    "@education/typescript-config": "0.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "19.2.2",
    "eslint": "^9.39.4",
    "expect": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.13",
    "node-edge-tts": "^1.2.8",
    "react-test-renderer": "19.2.0",
    "typescript": "5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "\\.css$": "<rootDir>/test/style-mock.js",
      "\\.mp3$": "<rootDir>/test/style-mock.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  }
}
